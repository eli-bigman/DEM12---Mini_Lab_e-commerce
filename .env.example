# ============================================================
# Mini Data Platform - Environment Variables Example
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to version control.
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=<your_postgres_password>

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=<your_minio_password>
MINIO_RAW_BUCKET=raw-data

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=<your_airflow_admin_password>
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_WEBSERVER_SECRET_KEY=<your_airflow_webserver_secret_key>
AIRFLOW__CORE__FERNET_KEY=<your_airflow_fernet_key>

# --- Metabase ---
MB_DB_TYPE=postgres
MB_DB_DBNAME=metabase
MB_DB_PORT=5432
MB_DB_USER=metabase_user
MB_DB_PASS=<your_metabase_password>
MB_DB_HOST=postgres
METABASE_ADMIN_EMAIL=admin@example.com
METABASE_ADMIN_PASSWORD=<your_metabase_admin_password>

# --- Data Collector ---
COLLECTOR_BATCH_INTERVAL_SECONDS=30
COLLECTOR_BATCH_SIZE=50
